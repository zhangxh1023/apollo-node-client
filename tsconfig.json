{
  "compilerOptions": {
    "target": "ES2018",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node", "jest"],
    "esModuleInterop": true,
    "strictNullChecks": true,
    "noImplicitAny": false,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "./index.ts",
    "./lib/*.ts",
    "./test/*.ts"
  ]
}
